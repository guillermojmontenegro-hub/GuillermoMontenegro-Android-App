    <string name="onboarding_step_1_title">Profile and navigation</string>
    <string name="onboarding_step_1_technology">Jetpack Compose</string>
    <string name="onboarding_step_1_description">This screen shows navigation, declarative layout, and a modern look built with Jetpack Compose. The drawer and home screen demonstrate how to build a flexible native UI with Compose.</string>
    <string name="onboarding_step_1_hint">Open the drawer from the top-left icon to see how Compose handles navigation, visual hierarchy, and interactive surfaces.</string>
    <string name="onboarding_step_2_title">Read articles</string>
    <string name="onboarding_step_2_technology">Retrofit</string>
    <string name="onboarding_step_2_description">The technical library is designed to show service consumption with Retrofit. Although the backend is currently mocked inside the app, the flow uses a real HTTP client, repository, and data parsing as if it talked to an external API.</string>
    <string name="onboarding_step_2_hint">From the home screen, tap the “Read articles” FAB to trigger the remote load and browse the content received by Retrofit.</string>
    <string name="onboarding_step_3_title">User CRUD</string>
    <string name="onboarding_step_3_technology">Room</string>
    <string name="onboarding_step_3_description">The user CRUD exists to show local persistence with Room. Create, edit, list, and delete operations are stored in the device database and reappear when reopening the app.</string>
    <string name="onboarding_step_3_hint">Use “Create user”, “User list”, and “Edit active user” to go through the full Room-persisted flow.</string>
